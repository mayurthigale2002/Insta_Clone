<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Creative Instagram Messages</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif}

body{
  background:#0b0b0f;
  color:#fff;
  display:flex;
  height:100vh;
  overflow:hidden;
}

/* SIDEBAR */
.sidebar{
  width:230px;
  background:#000;
  padding:20px;
  border-right:1px solid #1a1a1a;
}

.logo{
  font-size:22px;
  font-weight:bold;
  margin-bottom:30px;
  background:linear-gradient(45deg,#f58529,#dd2a7b,#8134af);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.nav a{
  display:flex;
  align-items:center;
  gap:12px;
  padding:10px;
  margin:6px 0;
  color:#ccc;
  text-decoration:none;
  border-radius:10px;
  transition:0.3s;
}

.nav a:hover{
  background:#121212;
  color:#fff;
}

/* CHAT LIST */
.chat-list{
  width:320px;
  background:#0f0f14;
  border-right:1px solid #1a1a1a;
  display:flex;
  flex-direction:column;
}

.chat-header{
  padding:15px;
  font-weight:bold;
  border-bottom:1px solid #1a1a1a;
  display:flex;
  justify-content:space-between;
}

.chat{
  display:flex;
  align-items:center;
  padding:12px;
  cursor:pointer;
  transition:0.2s;
}

.chat:hover{
  background:#181820;
}

.profile-pic{
  width:45px;
  height:45px;
  border-radius:50%;
  background:linear-gradient(45deg,#f58529,#dd2a7b);
}

.chat-info{margin-left:10px}
.chat-name{font-weight:bold}
.chat-msg{font-size:13px;color:#888}

/* CHAT WINDOW */
.chat-window{
  flex:1;
  display:flex;
  flex-direction:column;
  background:#000;
}

.chat-top{
  padding:15px;
  border-bottom:1px solid #1a1a1a;
  display:flex;
  align-items:center;
  gap:10px;
}

.status{
  font-size:12px;
  color:#4caf50;
}

.messages{
  flex:1;
  padding:20px;
  overflow-y:auto;
  display:flex;
  flex-direction:column;
}

.msg{
  max-width:60%;
  padding:12px 16px;
  border-radius:20px;
  margin-bottom:12px;
  font-size:14px;
  position:relative;
  animation:fadeIn 0.3s ease;
}

@keyframes fadeIn{
  from{opacity:0;transform:translateY(10px)}
  to{opacity:1;transform:translateY(0)}
}

.sent{
  background:linear-gradient(45deg,#8134af,#dd2a7b);
  margin-left:auto;
}

.received{
  background:#1c1c24;
}

.msg::after{
  content:'';
  position:absolute;
  bottom:-2px;
  width:10px;
  height:10px;
  background:inherit;
  transform:rotate(45deg);
}

.sent::after{right:5px}
.received::after{left:5px}

/* INPUT */
.input-box{
  display:flex;
  align-items:center;
  padding:10px;
  border-top:1px solid #1a1a1a;
  background:#0f0f14;
}

.input-box input{
  flex:1;
  background:#181820;
  border:none;
  border-radius:25px;
  padding:12px;
  color:#fff;
  outline:none;
}

.send{
  margin-left:10px;
  padding:8px 14px;
  border-radius:20px;
  background:linear-gradient(45deg,#f58529,#dd2a7b);
  cursor:pointer;
  font-size:13px;
  font-weight:bold;
  transition:0.3s;
}

.send:hover{
  transform:scale(1.05);
}

</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="logo">Instagram</div>
  <div class="nav">
    <a href="/dashboard">🏠 Home</a>
    <a href="/messages">💬 Messages</a>
    <a href="profile">👤 Profile</a>
  </div>
</div>

<!-- CHAT LIST -->
<div class="chat-list">
  <div class="chat-header">
    Messages
    <span>✏️</span>
  </div>

  <div class="chat">
    <div class="profile-pic"></div>
    <div class="chat-info">
      <div class="chat-name">user1</div>
      <div class="chat-msg">Typing...</div>
    </div>
  </div>

  <div class="chat">
    <div class="profile-pic"></div>
    <div class="chat-info">
      <div class="chat-name">user2</div>
      <div class="chat-msg">Seen 2h ago</div>
    </div>
  </div>

</div>

<!-- CHAT WINDOW -->
<div class="chat-window">

  <div class="chat-top">
    <div class="profile-pic"></div>
    <div>
      <div>user1</div>
      <div class="status">Online</div>
    </div>
  </div>

  <div class="messages">
    <div class="msg received">Hey 👋</div>
    <div class="msg sent">Yo 🔥</div>
    <div class="msg received">This UI looks sick 😎</div>
    <div class="msg sent">Yeah bro it's creative 💯</div>
  </div>

  <div class="input-box">
    <input type="text" placeholder="Message...">
    <div class="send">Send</div>
  </div>

</div>

</body>
</html>
