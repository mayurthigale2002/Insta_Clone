<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Post & Reel</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #000, #111);
            color: #fff;
            display: flex;
        }

        /* SIDEBAR */
        .sidebar {
            width: 230px;
            height: 100vh;
            padding: 20px;
            border-right: 1px solid #222;
            position: fixed;
            background: #000;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 30px;
        }

        .nav a {
            display: block;
            padding: 12px;
            margin: 6px 0;
            color: #fff;
            text-decoration: none;
            border-radius: 10px;
            transition: 0.3s;
        }

        .nav a:hover {
            background: #1a1a1a;
            transform: translateX(5px);
        }

        /* MAIN */
        .container {
            margin-left: 250px;
            padding: 30px;
            width: 100%;
            max-width: 750px;
        }

        h2 {
            text-align: center;
        }

        .card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            padding: 20px;
            border-radius: 15px;
            margin-top: 20px;
            box-shadow: 0 0 15px rgba(0,0,0,0.4);
        }

        input, textarea {
            width: 100%;
            margin: 10px 0;
            padding: 12px;
            border-radius: 8px;
            border: none;
            background: #222;
            color: #fff;
        }

        button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(45deg, #3897f0, #4aa3ff);
            border: none;
            color: #fff;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            transform: scale(1.03);
        }

        .preview {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .preview-box {
            position: relative;
        }

        .preview img,
        .preview video {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 8px;
        }

        .remove-btn {
            position: absolute;
            top: -5px;
            right: -5px;
            background: red;
            border-radius: 50%;
            color: #fff;
            font-size: 12px;
            width: 20px;
            height: 20px;
            text-align: center;
            cursor: pointer;
        }

        hr {
            margin: 30px 0;
            border: 1px solid #222;
        }

        @media (max-width: 768px) {
            .sidebar {
                display: none;
            }
            .container {
                margin-left: 0;
            }
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">Instagram</div>

        <div class="nav">
            <a href="/dashboard">🏠 Home</a>
            <a href="/profile">👤 Profile</a>
            <a href="/logout">🚪 Logout</a>
        </div>
    </div>

    <!-- MAIN -->
    <div class="container">
        <h2>Create</h2>

        <!-- POST -->
        <div class="card">
            <h3>Upload Post 📸</h3>

            <form action="/create-post" method="post" enctype="multipart/form-data">
                <input type="file" name="userPost" id="postInput" multiple accept="image/*">
                <textarea name="caption" placeholder="Write caption..."></textarea>

                <div class="preview" id="postPreview"></div>

                <button type="submit">Upload Post</button>
            </form>
        </div>

        <hr>

        <!-- REEL -->
        <div class="card">
            <h3>Upload Reel 🎥</h3>

            <form action="/create-reel" method="post" enctype="multipart/form-data">
                <input type="file" name="userReel" id="reelInput" multiple accept="video/*">
                <textarea name="caption" placeholder="Write caption..."></textarea>

                <div class="preview" id="reelPreview"></div>

                <button type="submit">Upload Reel</button>
            </form>
        </div>
    </div>

    <!-- JS -->
    <script>
        function previewFiles(inputId, previewId, type) {
            const input = document.getElementById(inputId);
            const preview = document.getElementById(previewId);

            input.addEventListener("change", function (e) {
                preview.innerHTML = "";

                Array.from(e.target.files).forEach((file, index) => {

                    // validation
                    if (type === "image" && !file.type.startsWith("image/")) {
                        alert("Only images allowed!");
                        return;
                    }

                    if (type === "video" && !file.type.startsWith("video/")) {
                        alert("Only videos allowed!");
                        return;
                    }

                    const box = document.createElement("div");
                    box.classList.add("preview-box");

                    let element;
                    if (type === "image") {
                        element = document.createElement("img");
                    } else {
                        element = document.createElement("video");
                        element.controls = true;
                    }

                    element.src = URL.createObjectURL(file);

                    const remove = document.createElement("div");
                    remove.innerText = "×";
                    remove.classList.add("remove-btn");

                    remove.onclick = () => box.remove();

                    box.appendChild(element);
                    box.appendChild(remove);
                    preview.appendChild(box);
                });
            });
        }

        previewFiles("postInput", "postPreview", "image");
        previewFiles("reelInput", "reelPreview", "video");
    </script>

</body>

</html>